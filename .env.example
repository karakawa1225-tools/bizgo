# --- Turso（サーバー＝Next.js API から接続。ブラウザには出しません）---
# 推奨の変数名:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 代替（libSQL 系ツールが出す名前の場合）:
# LIBSQL_DATABASE_URL=
# LIBSQL_AUTH_TOKEN=

# --- アプリ用の簡易認証（Turso とは別。Web から API を叩くときの合言葉）---
# 8 文字以上。チーム内で共有するマスターパスワード。
BIZGO_CLOUD_PASSWORD=

# 16 文字以上。セッション Cookie の署名用（漏らさないこと）。
BIZGO_CLOUD_SESSION_SECRET=

# --- PDF 帳票（任意）---
# 出張・経費 PDF の右上に表示する会社名
# NEXT_PUBLIC_BIZGO_PDF_COMPANY_NAME=株式会社○○
